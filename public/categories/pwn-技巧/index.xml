            <title>Piggyback 输入流复用技巧</title>
            <link>http://localhost:1313/p/piggyback-%E8%BE%93%E5%85%A5%E6%B5%81%E5%A4%8D%E7%94%A8%E6%8A%80%E5%B7%A7/</link>
